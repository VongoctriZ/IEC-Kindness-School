# Sao chép file này thành .env rồi điền giá trị thật vào
# cp .env.example .env

VITE_APP_NAME=IEC-KindnessSchool

# ── Firebase Web App ──────────────────────────────────────────────────────────
# Lấy tại: Firebase Console → Project Settings → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Seed script (chỉ cần khi chạy scripts/seed.js) ───────────────────────────
# Tên file Firebase Admin SDK JSON (đặt ở root, đã gitignore)
# Lấy tại: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_ADMIN_KEY_FILE=../your-project-adminsdk.json

# Mật khẩu cho các tài khoản seed (chỉ dùng cho dữ liệu test)
SEED_PASSWORD=
