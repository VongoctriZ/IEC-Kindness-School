rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: kiểm tra user hiện tại có role teacher không
    function isTeacher() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == uid;

      // Update: chỉ owner, nhưng giới hạn field nào được sửa
      allow update: if request.auth.uid == uid
        && (
          // Cập nhật thông tin hồ sơ (không đụng totalPoints)
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'grade', 'photoURL', 'coverURL'])
          ||
          // Cộng điểm: chỉ được tăng theo các mức quy định
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPoints'])
            && (request.resource.data.totalPoints - resource.data.totalPoints)
               in [2, 5, 10, 20]
          )
        );
    }

    // ── Posts ─────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      // Author sửa bài; ai cũng có thể update likeCount/commentCount
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.authorId
            || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['likeCount', 'commentCount']));

      // Author hoặc giáo viên có thể xoá bài
      allow delete: if request.auth.uid == resource.data.authorId || isTeacher();

      match /likes/{likeUid} {
        allow read:  if request.auth != null;
        allow write: if request.auth.uid == likeUid;
      }
    }

    // ── Comments ─────────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      // Author hoặc giáo viên có thể xoá comment
      allow delete: if request.auth.uid == resource.data.authorId || isTeacher();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{uid}/items/{notifId} {
      allow read:   if request.auth.uid == uid;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == uid;  // mark as read
      allow delete: if request.auth.uid == uid;
    }
  }
}
